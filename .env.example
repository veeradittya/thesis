# Copy to .env.local and fill in.

# --- Thesis decomposition + Copilot (need ONE of these) ---
# Dartmouth Claude gateway (OpenAI-compatible) — primary
DARTMOUTH_API_KEY=
DARTMOUTH_GATEWAY_BASE=https://chat.dartmouth.edu/api
DARTMOUTH_MODEL=anthropic.claude-sonnet-4-5-20250929
# Anthropic API — fallback
ANTHROPIC_API_KEY=

# --- Plaid brokerage linking ---  (create free at dashboard.plaid.com)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Data sources (monitoring engine) ---
FINNHUB_API_KEY=
FRED_API_KEY=
NYT_API_KEY=
GUARDIAN_API_KEY=
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
