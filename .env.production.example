# betathesis.com production env TEMPLATE (safe to commit — placeholders only).
# Copy to `.env.production` (gitignored) and fill real values, then place on anton at
# /home/veer/betathesis/.env.production. Loaded via the systemd EnvironmentFile.
# Every key below is read at runtime by the standalone server; a missing one silently
# breaks that feature (markets / news / prices / chart / chat / signals / auth).

NODE_ENV=production

# --- Auth.js (Google sign-in) ---
NEXTAUTH_URL=https://betathesis.com
AUTH_URL=https://betathesis.com
AUTH_TRUST_HOST=true
AUTH_SECRET=            # openssl rand -base64 32  (use a NEW one, not the dev secret)
AUTH_GOOGLE_ID=         # Google Cloud OAuth 2.0 client id (add prod redirect URIs — Phase 7)
AUTH_GOOGLE_SECRET=     # Google Cloud OAuth 2.0 client secret

# --- Prediction markets (Oddpool: Kalshi + Polymarket) — CORE ---
ODDPOOL_API_KEY=

# --- News ---
GUARDIAN_API_KEY=
NYT_API_KEY=

# --- Live prices (Finnhub) + chart history (Alpaca IEX) ---
FINNHUB_API_KEY=
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# --- LLM (Dartmouth Claude gateway primary; Anthropic fallback) ---
DARTMOUTH_API_KEY=
DARTMOUTH_GATEWAY_BASE=https://chat.dartmouth.edu/api
DARTMOUTH_MODEL=anthropic.claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=

# --- Plaid (sandbox; dormant) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- FRED (present for parity; not currently read) ---
FRED_API_KEY=
